# LLM Configuration — default model used when per-phase model is not set
SYNAPSE_LLM_API_KEY=sk-...
SYNAPSE_LLM_BASE_URL=https://openrouter.ai/api/v1
SYNAPSE_LLM_MODEL=openrouter/auto
SYNAPSE_LLM_TIMEOUT=180

# Per-phase model overrides (leave empty to use LLM_MODEL)
# SYNAPSE_BOOTSTRAP_MODEL=anthropic/claude-sonnet-4
# SYNAPSE_EXTRACTION_MODEL=google/gemini-2.5-pro
# SYNAPSE_CHAT_MODEL=anthropic/claude-sonnet-4

# FalkorDB
SYNAPSE_FALKORDB_HOST=localhost
SYNAPSE_FALKORDB_PORT=6379
SYNAPSE_FALKORDB_PASSWORD=
SYNAPSE_GRAPH_NAME=synapse_kg

# Instance state — set after bootstrap completes
# SYNAPSE_INSTANCE_DIR will default to ~/.synapse/<graph_name>/
# It stores: generated ontology, generated prompts, text cache

# Extraction
SYNAPSE_ONTOLOGY=base
SYNAPSE_SECTION_TIMEOUT=600

# Bootstrap
SYNAPSE_BOOTSTRAP_SAMPLE_PAGES=30
SYNAPSE_BOOTSTRAP_MAX_ENTITY_TYPES=15
SYNAPSE_BOOTSTRAP_MAX_REL_TYPES=20
